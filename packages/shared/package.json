{
  "name": "@haive/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared types, schemas, crypto, and utilities for Haive",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "import": "./dist/schemas/index.js"
    },
    "./crypto": {
      "types": "./dist/crypto/index.d.ts",
      "import": "./dist/crypto/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js"
    },
    "./logger": {
      "types": "./dist/logger/index.d.ts",
      "import": "./dist/logger/index.js"
    },
    "./constants": {
      "types": "./dist/constants/index.d.ts",
      "import": "./dist/constants/index.js"
    },
    "./rag": {
      "types": "./dist/rag/index.d.ts",
      "import": "./dist/rag/index.js"
    },
    "./global-kb": {
      "types": "./dist/global-kb/index.d.ts",
      "import": "./dist/global-kb/index.js"
    },
    "./timing": {
      "types": "./dist/step-engine/timing.d.ts",
      "import": "./dist/step-engine/timing.js"
    },
    "./claude-oauth": {
      "types": "./dist/cli-providers/claude-oauth.d.ts",
      "import": "./dist/cli-providers/claude-oauth.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@haive/database": "workspace:*",
    "drizzle-orm": "0.45.2",
    "ioredis": "^5.4.2",
    "pino": "^10.3.1",
    "pino-pretty": "^11.3.0",
    "postgres": "^3.4.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  }
}
