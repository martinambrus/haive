{
  "name": "@haive/api",
  "version": "0.1.0",
  "private": true,
  "description": "Hono REST API server for Haive",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@haive/database": "workspace:*",
    "@haive/shared": "workspace:*",
    "@hono/node-server": "^1.14.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.34.8",
    "dockerode": "^4.0.4",
    "drizzle-orm": "0.45.1",
    "hono": "^4.7.4",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "prom-client": "^15.1.3",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/dockerode": "^4.0.1",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  }
}
