# ============================================================================
# haive environment configuration
# Copy to .env and fill in real values for local development.
# ============================================================================

# --- Runtime ----------------------------------------------------------------
NODE_ENV=development
API_PORT=3001
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001
# Server-side API URL used by the web container for SSR calls to the api
# service (e.g. /auth/me in the app layout). Inside docker-compose the web
# container must reach api via the service hostname, not localhost.
API_URL_INTERNAL=http://api:3001

# --- PostgreSQL -------------------------------------------------------------
POSTGRES_USER=haive
POSTGRES_PASSWORD=haive_dev_password
POSTGRES_DB=haive
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://haive:haive_dev_password@postgres:5432/haive

# --- Redis ------------------------------------------------------------------
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# --- Crypto / Auth ----------------------------------------------------------
# 32-byte hex key for envelope encryption (master KEK).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CONFIG_ENCRYPTION_KEY=replace_with_32_byte_hex_key

# JWT signing secret (any sufficiently long random string).
JWT_SECRET=replace_with_long_random_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- SMTP (Mailpit in dev) --------------------------------------------------
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@haive.local

# --- Filesystem browser -----------------------------------------------------
# Host path mounted read-only into the api container so the local-path
# repository picker can browse the user's files. Default: user $HOME.
HOST_REPO_ROOT=${HOME}

# --- Sandbox / clawker ------------------------------------------------------
# Tagged clawker release pinned in Dockerfile.worker; override here only if
# you've installed a different version on the worker image.
CLAWKER_BIN=/usr/local/bin/clawker
SANDBOX_NETWORK=haive-network

# Host-side path to the Docker socket the worker container mounts at
# /var/run/docker.sock. Default is the root-privileged socket. To run
# against a rootless Docker daemon instead, set this to your rootless
# socket path, e.g. /run/user/$(id -u)/docker.sock. See README.md
# "Docker socket exposure" for the full rootless setup walkthrough.
DOCKER_SOCKET=/var/run/docker.sock

# --- GitHub OAuth (device-code flow) ----------------------------------------
# Client ID of a GitHub OAuth App with "Device Flow" enabled. Required only
# when users pick source=github_oauth in the new-repo form. Leave empty to
# disable the OAuth sign-in button; HTTPS + personal access token still works.
# Falls back to the GITHUB_CLIENT_ID secret stored via secretsService if unset.
GITHUB_OAUTH_CLIENT_ID=
